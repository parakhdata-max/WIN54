# ==========================================================
# LEGACY COMPAT: search_patients
# ==========================================================

def search_patients(search_term: str) -> pd.DataFrame:
    """
    Search patients by name OR mobile.
    Returns all matches — multiple patients can share a mobile (family members).

    Identity model:
      name + mobile = unique patient
      Same mobile, different names = different family members (son, wife etc.)
      Same name, different mobile = different person (common name)
    """
    if not search_term:
        return pd.DataFrame()

    term = search_term.strip()
    sql = """
        SELECT
            id              AS patient_id,
            master_name     AS patient_name,
            mobile,
            COALESCE(relation,'Self')   AS relation,
            COALESCE(gender,'')         AS gender,
            COALESCE(ref_mobile,'')     AS ref_mobile,
            record_no
        FROM patients
        WHERE master_name ILIKE %s
           OR mobile ILIKE %s
           OR ref_mobile ILIKE %s
           OR barcode ILIKE %s
           OR record_no ILIKE %s
        ORDER BY master_name
        LIMIT 30
    """
    return execute_query(sql, "patient_search",
                         params=(f"%{term}%", f"%{term}%", f"%{term}%",
                                 f"%{term}%", f"%{term}%"))
