# -------------------------------------------------
# SUPPLIER ORDERS (COMPLETE SYSTEM)
# -------------------------------------------------

def save_supplier_order(supplier_order: dict):
    """
    Save or update supplier order with items + history
    ✅ NaN-safe with automatic sanitization
    """

    conn = None
    cursor = None

    try:
        conn = get_transaction_connection()
        cursor = conn.cursor()

        so_id = supplier_order['supplier_order_id']

        # Check if exists
        cursor.execute(
            "SELECT 1 FROM supplier_orders WHERE supplier_order_id = %s",
            (so_id,)
        )

        exists = cursor.fetchone()

        if exists:
            # ---------- UPDATE ----------
            cursor.execute("""
                UPDATE supplier_orders
                SET
                    supplier_id = %s,
                    order_date = %s,
                    status = %s,
                    expected_delivery = %s,
                    notes = %s,
                    total_amount = %s,
                    updated_at = NOW()
                WHERE supplier_order_id = %s
            """, (
                supplier_order.get('supplier_id'),
                supplier_order.get('order_date'),
                supplier_order.get('status', 'PENDING'),
                supplier_order.get('expected_delivery'),
                supplier_order.get('notes'),
                supplier_order.get('total_amount', 0),
                so_id
            ))

            # Delete old items
            cursor.execute(
                "DELETE FROM supplier_order_items WHERE supplier_order_id = %s",
                (so_id,)
            )

        else:
            # ---------- INSERT ----------
            cursor.execute("""
                INSERT INTO supplier_orders (
                    supplier_order_id,
                    supplier_id,
                    order_date,
                    status,
                    expected_delivery,
                    notes,
                    total_amount,
                    created_by
                )
                VALUES (%s,%s,%s,%s,%s,%s,%s,%s)
            """, (
                so_id,
                supplier_order.get('supplier_id'),
                supplier_order.get('order_date'),
                supplier_order.get('status', 'PENDING'),
                supplier_order.get('expected_delivery'),
                supplier_order.get('notes'),
                supplier_order.get('total_amount', 0),
                supplier_order.get('created_by', 'system')
            ))

        # ---------- Items ----------
        for item in supplier_order.get('items', []):
            
            # Sanitize all item values
            sanitized_item = {k: _sanitize_value(v) for k, v in item.items()}
            
            cursor.execute("""
                INSERT INTO supplier_order_items (
                    supplier_order_id,
                    item_no,
                    product_id,
                    product_name,
                    brand,
                    eye_side,
                    sph,
                    cyl,
                    axis,
                    add_power,
                    ordered_qty,
                    received_qty,
                    pending_qty,
                    unit_price,
                    total_price,
                    customer_line_id,
                    item_status
                )
                VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s)
            """, (
                so_id,
                sanitized_item.get('item_no'),
                sanitized_item.get('product_id'),
                sanitized_item['product_name'],
                sanitized_item.get('brand'),
                sanitized_item.get('eye_side'),
                sanitized_item.get('sph'),
                sanitized_item.get('cyl'),
                sanitized_item.get('axis'),
                sanitized_item.get('add_power'),
                sanitized_item['ordered_qty'],
                sanitized_item.get('received_qty', 0),
                sanitized_item['pending_qty'],
                sanitized_item.get('unit_price', 0),
                sanitized_item.get('total_price', 0),
                sanitized_item.get('customer_line_id'),
                sanitized_item.get('item_status', 'PENDING')
            ))

        # ---------- Status History ----------
        for h in supplier_order.get('status_history', []):

            cursor.execute("""
                INSERT INTO supplier_order_status_history (
                    supplier_order_id,
                    status,
                    timestamp,
                    notes,
                    changed_by
                )
                VALUES (%s,%s,%s,%s,%s)
            """, (
                so_id,
                h.get('status'),
                h.get('timestamp'),
                h.get('notes'),
                h.get('changed_by', 'system')
            ))

        conn.commit()
        return True


    except Exception as e:
        if conn:
            conn.rollback()

        logger.error(f"save_supplier_order failed: {e}")
        raise QueryError(e)

    finally:
        if cursor:
            cursor.close()
        if conn:
            conn.close()


def fetch_supplier_orders():
    """
    Fetch all supplier orders with items + history
    ✅ NaN-safe results
    """

    conn = None
    cursor = None

    try:
        conn = get_transaction_connection()
        cursor = conn.cursor(cursor_factory=RealDictCursor)

        # --------- Orders ----------
        cursor.execute("""
            SELECT *
            FROM supplier_orders
            ORDER BY order_date DESC
        """)

        orders = cursor.fetchall()

        results = []

        for order in orders:

            # Use integer PK (id) to join items/history — supplier_order_id is varchar ref code
            so_pk = int(order['id'])

            # -------- Items ----------
            cursor.execute("""
                SELECT *
                FROM supplier_order_items
                WHERE supplier_order_id = %s
                ORDER BY item_no
            """, (so_pk,))

            items = cursor.fetchall()

            # -------- History ----------
            cursor.execute("""
                SELECT *
                FROM supplier_order_status_history
                WHERE supplier_order_id = %s
                ORDER BY timestamp DESC
            """, (so_pk,))

            history = cursor.fetchall()

            # Sanitize nested data
            order['items'] = [
                {k: _sanitize_value(v) for k, v in dict(item).items()}
                for item in items
            ]
            order['status_history'] = [
                {k: _sanitize_value(v) for k, v in dict(h).items()}
                for h in history
            ]

            results.append(dict(order))

        return results


    except Exception as e:

        logger.error(f"fetch_supplier_orders failed: {e}")
        raise QueryError(e)

    finally:

        if cursor:
            cursor.close()

        if conn:
            conn.close()


def update_supplier_order_status(
    supplier_order_id: str,
    new_status: str,
    notes: str = None,
    changed_by: str = "system"
):
    """
    Update supplier order status + history
    """

    conn = None
    cursor = None

    try:
        conn = get_transaction_connection()
        cursor = conn.cursor()

        # Update main table
        cursor.execute("""
            UPDATE supplier_orders
            SET status = %s,
                updated_at = NOW()
            WHERE supplier_order_id = %s
        """, (
            new_status,
            supplier_order_id
        ))

        # Insert history
        cursor.execute("""
            INSERT INTO supplier_order_status_history (
                supplier_order_id,
                status,
                notes,
                changed_by
            )
            VALUES (%s,%s,%s,%s)
        """, (
            supplier_order_id,
            new_status,
            notes,
            changed_by
        ))

        conn.commit()
        return True


    except Exception as e:

        if conn:
            conn.rollback()

        logger.error(f"update_supplier_order_status failed: {e}")
        raise QueryError(e)

    finally:

        if cursor:
            cursor.close()

        if conn:
            conn.close()


def fetch_orders_with_lines(order_nos: list):
    """
    Fetch multiple orders + lines + products in ONE query
    (Fast + Stable batch loader)
    ✅ NaN-safe DataFrame
    """

    if not order_nos:
        return None

    conn = None

    try:
        conn = get_connection()

        sql = """
            SELECT
                o.id AS order_id,
                o.order_no,
                o.created_at,
                o.status,
                o.patient_name,
                o.party_name,
                o.order_type,

                l.id AS line_id,
                l.order_id AS line_order_id,
                l.product_id,
                l.sph,
                l.cyl,
                l.axis,
                l.add_power,
                l.eye_side,
                l.quantity AS billing_qty,
                l.unit_price,
                l.total_price AS billing_total,
                l.gst_percent,
                l.gst_amount,
                l.status AS batch_status,
                l.allocated_qty,
                COALESCE(l.ready_qty, 0) AS ready_qty,
                l.lens_params,
                l.boxing_params,

                p.main_group,
                p.product_name,
                p.brand,
                p.gst_percent AS product_gst_percent

            FROM orders o

            LEFT JOIN order_lines l
                ON  o.id = l.order_id
                AND COALESCE(l.is_deleted, FALSE) = FALSE

            LEFT JOIN products p
                ON l.product_id = p.id

            WHERE o.order_no = ANY(%s)

            ORDER BY o.created_at DESC
        """

        df = pd.read_sql(sql, conn, params=(order_nos,))
        
        # Sanitize DataFrame
        df = df.where(pd.notnull(df), None)

        return df


    except Exception as e:

        logger.error(f"Batch fetch failed: {e}")
        raise


    finally:

        if conn:
            conn.close()


# ==========================================================
# 🔥 POWER-WISE STOCK (HARDENED VERSION)
# Fully NaN-safe, NULL-safe, injection-safe
# ==========================================================

def get_power_wise_stock(product_id, sph, cyl=None, axis=None, add_power=None):
    """
    Returns total PCS stock for given product + power
    ✅ NULL-safe with IS NOT DISTINCT FROM
    ✅ NaN-safe with automatic sanitization
    ✅ SQL injection-safe with parameterized queries
    ✅ Dynamic filtering (only adds filters for provided values)
    
    Args:
        product_id: Product ID (required)
        sph: Spherical power (required, can be None/NaN)
        cyl: Cylindrical power (optional)
        axis: Axis (optional)
        add_power: Addition power (optional)
    
    Returns:
        int: Total quantity in PCS
    """
    
    sql = """
        SELECT COALESCE(SUM(quantity), 0) AS total_qty
        FROM inventory_stock
        WHERE product_id = %s
        AND is_active = true
    """
    
    params = [product_id]
    
    # Add ALL power filters dynamically using helper (including sph)
    sql, params = add_power_filters(sql, params, sph, cyl, axis, add_power)
    
    df = execute_query(sql, "power_stock", params=tuple(params))
    
    if df.empty:
        return 0
    
    return int(df.iloc[0]["total_qty"] or 0)


