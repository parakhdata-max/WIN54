def get_patient_last_visit(patient_id: int):
    """
    Returns latest visit record_no for a patient
    Used in retail auto-Rx loading
    """
    sql = """
        SELECT record_no
        FROM patient_visits
        WHERE patient_id = %s
        ORDER BY visit_date DESC
        LIMIT 1
    """

    df = execute_query(sql, "patient_last_visit", params=(patient_id,))

    if df.empty:
        return None

    return df.iloc[0]["record_no"]
# ==========================================================
# LEGACY COMPAT: read_frame_sku
# ==========================================================

def read_frame_sku() -> pd.DataFrame:
    """
    Frame stock reader — joins inventory_stock for mrp/selling_price/quantity.
    mrp   = retail counter price (COALESCED so retail pricing always works)
    selling_price = W/S trade price
    """
    sql = """
        SELECT
            s.id,
            s.product_id,
            s.batch_no,
            s.eye_side,
            s.quantity,
            COALESCE(s.selling_price, 0)               AS selling_price,
            COALESCE(s.mrp, s.selling_price, 0)        AS mrp,
            COALESCE(s.purchase_rate, 0)               AS purchase_rate,
            p.product_name,
            p.brand,
            p.category,
            COALESCE(p.unit, 'PCS')                    AS unit,
            COALESCE(p.box_size, 1)                    AS box_size,
            COALESCE(p.allow_loose, false)             AS allow_loose,
            s.location,
            s.created_at,
            s.updated_at
        FROM inventory_stock s
        JOIN products p ON p.id = s.product_id
        WHERE LOWER(p.category) = 'frame'
          AND COALESCE(s.is_active, true) = true
          AND COALESCE(p.is_active, true) = true
        ORDER BY p.product_name
    """
    return execute_query(sql, "frame_products")
# ==========================================================
# LEGACY COMPAT: fetch_backoffice_orders
# ==========================================================

def fetch_backoffice_orders(
    start_date: str = None,
    end_date: str = None,
    limit: int = 10,
    offset: int = 0,
    include_closed: bool = False,
):
    """
    Fetch orders for backoffice display — headers ONLY (no JOIN to lines).
    Lines are batch-fetched separately in load_orders_from_database().

    Smart loading:
      - Default limit=10 (auto-load on page open)
      - Caller passes offset for "load more"
      - Active orders only by default; include_closed for history
      - Headers-only query is fast: no JOIN to order_lines
    """
    sql = """
        SELECT
            o.id              AS order_id,
            o.order_no,
            o.display_order_no,
            o.created_at,
            o.status,
            o.patient_name,
            o.party_name,
            o.party_id,
            o.order_type,
            o.total_value,
            o.patient_mobile,
            o.customer_order_no,
            o.expected_supply_date,
            COALESCE(o.extra_data, '{}'::jsonb) AS extra_data
        FROM orders o
        WHERE COALESCE(o.is_deleted, FALSE) = FALSE
    """

    params = []

    if not include_closed:
        sql += " AND o.status NOT IN ('CLOSED', 'DELIVERED', 'CANCELLED', 'RETURNED')"

    sql += " AND UPPER(COALESCE(o.order_type,'')) != 'CONSULTATION'"

    if start_date:
        sql += " AND o.created_at >= %s"
        params.append(start_date)

    if end_date:
        sql += " AND o.created_at <= %s"
        params.append(end_date)

    sql += " ORDER BY o.created_at DESC, o.id DESC"

    _limit = max(1, int(limit or 10))
    sql += f" LIMIT {_limit}"

    if offset:
        sql += f" OFFSET {int(offset)}"

    return execute_query(
        sql,
        "backoffice_orders",
        params=tuple(params) if params else None
    )
# ==========================================================
# LEGACY COMPAT: get_database_info
# ==========================================================

def get_database_info():
    info = {}

    try:
        version_df = execute_query("SELECT version()", "db_info")
        info["postgres_version"] = version_df.iloc[0, 0] if not version_df.empty else "unknown"

        db_df = execute_query("SELECT current_database()", "db_info")
        info["database"] = db_df.iloc[0, 0] if not db_df.empty else DB_CONFIG.get("dbname")

        conn_df = execute_query("SELECT COUNT(*) FROM pg_stat_activity", "db_info")
        info["active_connections"] = int(conn_df.iloc[0, 0]) if not conn_df.empty else 0

        info["status"] = "ok"        # ✅ UI expects this
        info["connected"] = True    # ✅ extra compatibility

    except Exception as e:
        info["status"] = "error"
        info["connected"] = False
        info["error"] = str(e)

    return info
# ==========================================================
# SAFE LEGACY RESTORE (DataFrame-compatible)
# ==========================================================
import pandas as pd

def read_blank_inventory(
    category: str = None,
    material: str = None,
    brand: str = None,
    add_power: float = None,
    active_only: bool = True,
) -> pd.DataFrame:
    """
    Fetch blank inventory rows with optional filters.

    Filters applied only when the argument is not None:
      category    → exact match (case-insensitive)
      material    → exact match (case-insensitive)
      brand       → exact match (case-insensitive)
      add_power   → exact match OR NULL/0 rows included (0.25 tolerance)
      active_only → WHERE COALESCE(is_active, true) = true

    Returns a DataFrame with all blank_inventory columns.
    Returns empty DataFrame on any error (never crashes callers).

    NOTE: In this system, blank_inventory.material stores COATING type
    (e.g. "Clear", "Blue Cut", "Photo Sun") — not lens index.
    Callers use it as a display/selection filter, which is correct.
    """
    try:
        clauses = ["1=1"]
        params: dict = {}

        if active_only:
            clauses.append("COALESCE(is_active, true) = true")

        if category is not None:
            clauses.append("LOWER(category) = LOWER(%(category)s)")
            params["category"] = category

        if material is not None:
            clauses.append("LOWER(material) = LOWER(%(material)s)")
            params["material"] = material

        if brand is not None:
            clauses.append("LOWER(brand) = LOWER(%(brand)s)")
            params["brand"] = brand

        if add_power is not None:
            # Allow blanks whose add_power matches OR is NULL/0
            # (universal blanks work for any ADD in real labs)
            clauses.append(
                "(add_power IS NULL OR add_power = 0 "
                " OR ABS(add_power - %(add_power)s) < 0.01)"
            )
            params["add_power"] = float(add_power)

        where = " AND ".join(clauses)
        sql = f"""
            SELECT
                id,
                brand,
                category,
                material,
                colour,
                add_power,
                COALESCE(qty_right,       0) AS qty_right,
                COALESCE(qty_left,        0) AS qty_left,
                COALESCE(qty_independent, 0) AS qty_independent,
                base_recommended,
                base_1,
                base_2,
                base_3,
                batch_no,
                location,
                COALESCE(barcode,'')        AS barcode,
                COALESCE(item_code,'')      AS item_code,
                min_stock,
                cost_price,
                COALESCE(is_active, true)   AS is_active,
                created_at,
                updated_at
            FROM blank_inventory
            WHERE {where}
            ORDER BY brand, material, add_power NULLS LAST
        """
        return execute_query(sql, "blank_inventory", params=params or None)

    except Exception as exc:
        logger.warning(f"read_blank_inventory failed: {exc}")
        return pd.DataFrame()


def get_blank_base_curves(blank_id: str) -> pd.DataFrame:
    """
    Fetch base curve options for a specific blank.
    Returns rows with columns: base_recommended, base_1, base_2, base_3.
    Returns empty DataFrame on error.
    """
    try:
        sql = """
            SELECT
                id,
                base_recommended,
                base_1,
                base_2,
                base_3
            FROM blank_inventory
            WHERE id = %(blank_id)s::uuid
            LIMIT 1
        """
        return execute_query(sql, "blank_base_curves", params={"blank_id": str(blank_id)})
    except Exception as exc:
        logger.warning(f"get_blank_base_curves failed: {exc}")
        return pd.DataFrame()


def update_blank_quantity(
    blank_id: str,
    qty_change: int,
    eye_side: str = None,
) -> bool:
    """
    Decrement blank quantity after allocation.

    eye_side = "R"  → decrements qty_right
    eye_side = "L"  → decrements qty_left
    eye_side = None → decrements qty_independent

    Enforces no-negative constraint: skips update if current qty
    would go below 0 (returns False so caller can handle it).

    Returns True on success, False on failure or insufficient stock.
    """
    try:
        bid = str(blank_id)

        if eye_side and eye_side.upper() == "R":
            col = "qty_right"
        elif eye_side and eye_side.upper() == "L":
            col = "qty_left"
        else:
            col = "qty_independent"

        conn = get_transaction_connection()
        cur  = conn.cursor()
        try:
            # ── FOR UPDATE: lock the row so concurrent saves
            #    can't both read the same qty and both succeed ──
            cur.execute(
                f"SELECT {col} FROM blank_inventory "
                f"WHERE id = %(bid)s::uuid FOR UPDATE",
                {"bid": bid}
            )
            row = cur.fetchone()
            if row is None:
                return False   # blank not found

            current_qty = int(row[0] or 0)
            new_qty     = current_qty + int(qty_change)

            # Enforce no-negative at application layer (DB CHECK is backup)
            if new_qty < 0:
                conn.rollback()
                return False   # insufficient stock

            cur.execute(
                f"UPDATE blank_inventory "
                f"SET {col} = %(nq)s, updated_at = NOW() "
                f"WHERE id = %(bid)s::uuid",
                {"nq": new_qty, "bid": bid}
            )
            conn.commit()
            return True

        except Exception:
            conn.rollback()
            raise
        finally:
            cur.close()
            conn.close()

    except Exception as exc:
        logger.warning(f"update_blank_quantity failed: {exc}")
        return False


# ==========================================================
# PRICING FALLBACK: fetch_last_product_price
# Returns the last known unit_price from order_lines for a
# product — used when stock has no price stored.
# Called by backoffice_helpers.get_max_historical_price()
# ==========================================================

def fetch_last_product_price(product_id: str) -> float:
    """
    Fetch the last confirmed unit_price for a product from order_lines.
    This is the price the customer actually paid — most accurate fallback
    when inventory_stock has no selling_price recorded.

    Priority:
      1. Most recent order_line unit_price > 0
      2. inventory_stock selling_price / mrp (any power for that product)
      3. 0.0 if nothing found
    """
    try:
        pid = str(product_id)

        # 1. Last order line price for this product
        sql1 = """
            SELECT unit_price
            FROM order_lines
            WHERE product_id::text = %(pid)s
              AND unit_price > 0
            ORDER BY id DESC
            LIMIT 1
        """
        rows = run_query(sql1, {"pid": pid})
        if rows:
            v = float(rows[0].get("unit_price") or 0)
            if v > 0:
                return v

        # 2. inventory_stock selling_price (any power for this product)
        sql2 = """
            SELECT
                COALESCE(selling_price, mrp, purchase_rate, 0) AS price
            FROM inventory_stock
            WHERE product_id::text = %(pid)s
              AND COALESCE(is_active, true) = true
              AND COALESCE(selling_price, mrp, purchase_rate, 0) > 0
            ORDER BY updated_at DESC NULLS LAST
            LIMIT 1
        """
        rows2 = run_query(sql2, {"pid": pid})
        if rows2:
            v = float(rows2[0].get("price") or 0)
            if v > 0:
                return v

        return 0.0

    except Exception:
        return 0.0
