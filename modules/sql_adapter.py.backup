def read_orders(
    start_date: str = None,
    end_date: str = None,
    status: str = None
) -> pd.DataFrame:
    """
    Reads from 'orders' table
    Optional filters for date range and status
    """

    sql = """
        SELECT
            id as order_id,

            order_no,
            order_date,

            party_id,
            patient_name,

            prescription_id,

            status,

            subtotal,
            discount,
            tax_amount,
            total_amount,

            payment_status,
            payment_mode,

            notes,

            created_at,
            updated_at

        FROM orders

        WHERE 1=1
    """

    params = []

    if start_date:
        sql += " AND order_date >= %s"
