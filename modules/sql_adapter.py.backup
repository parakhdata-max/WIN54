    if end_date:
        sql += " AND order_date <= %s"
        params.append(end_date)

    if status:
        sql += " AND status = %s"
        params.append(status)

    sql += " ORDER BY order_date DESC, created_at DESC"

    return execute_query(sql, "orders", params=tuple(params) if params else None)


