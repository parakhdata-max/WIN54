def read_patient_visits(patient_id: Optional[str] = None) -> pd.DataFrame:
    """
    Retail-safe visits reader (legacy schema)
    """

    try:
        sql = """
            SELECT
                id as visit_id,
                patient_id,
                record_no as case_no,
                visit_date,
                visit_name,
                right_sph,
                right_cyl,
                right_axis,
                right_add as right_add_power,
                left_sph,
                left_cyl,
                left_axis,
                left_add as left_add_power,
                created_at
            FROM patient_visits
            WHERE 1=1
        """

        params = []

        if patient_id:
            sql += " AND patient_id = %s"
            params.append(patient_id)

        sql += " ORDER BY visit_date DESC, created_at DESC"

        df = execute_query(sql, "patient_visits", params=tuple(params) if params else None)
        return df if df is not None else pd.DataFrame()

    except Exception:
        return pd.DataFrame()


