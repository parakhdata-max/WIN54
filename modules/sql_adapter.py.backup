def read_patients(include_temporary: bool = False) -> pd.DataFrame:
    try:
        sql = """
            SELECT
                id::text as patient_id,  -- ✅ FORCE STRING ID
                master_name as patient_name,
                mobile AS mobile_number,
                record_no,
                is_temporary,
                created_at
            FROM patients
            WHERE 1=1
        """

        if not include_temporary:
            sql += " AND COALESCE(is_temporary, false) = false"

        sql += " ORDER BY created_at DESC"

        df = execute_query(sql, "patients")

        if df is None:
            return pd.DataFrame()

        # 🛡 Ensure no null IDs
        df["patient_id"] = df["patient_id"].fillna("").astype(str)

        return df

    except Exception:
        return pd.DataFrame()
# ==========================================================
# LEGACY COMPAT: read_ophthalmic_stock
# ==========================================================

def read_ophthalmic_stock() -> pd.DataFrame:
    """
    FINAL stock reader with pricing support
    Compatible with:
    - Retail pricing
    - Wholesale pricing
    - Last nail fallback
    """

    sql = """
        SELECT
            id,
            product_id,
            batch_no,
            sph,
            cyl,
            axis,
            add_power,
            eye_side,
            quantity,

            -- 🔥 PRICE FIELDS (CRITICAL)
            -- selling_price = W/S trade price
            -- mrp = retail counter/sticker price (GST inclusive)
            -- COALESCE ensures retail always gets a usable mrp even if only selling_price is set
            COALESCE(selling_price, 0)                    AS selling_price,
            COALESCE(mrp, selling_price, 0)               AS mrp,
            COALESCE(purchase_rate, 0)                    AS purchase_rate,

            location,
            COALESCE(is_active, true) as is_active,
            created_at,
            updated_at
        FROM inventory_stock
        WHERE COALESCE(is_active, true) = true
    """

    return execute_query(sql, "inventory_stock")


