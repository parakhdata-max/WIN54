# -------------------------------------------------
# INVENTORY TRANSACTIONS
# -------------------------------------------------

def read_inventory_transactions(
    start_date: str = None,
    end_date: str = None,
    product_id: int = None
) -> pd.DataFrame:
    """
    Reads from 'inventory_transactions' table
    Optional filters for date range and product
    """

    sql = """
        SELECT
            id as txn_id,

            txn_type,
            txn_date,

            product_id,
            batch_id,

            sph,
            cyl,
            axis,
            add_power,

            eye_side,

            quantity,
            unit_price,

            reference_type,
            reference_id,

            notes,

            created_at

        FROM inventory_transactions

        WHERE 1=1
    """

    params = []

    if start_date:
        sql += " AND txn_date >= %s"
        params.append(start_date)

    if end_date:
        sql += " AND txn_date <= %s"
        params.append(end_date)

    if product_id:
        sql += " AND product_id = %s"
        params.append(product_id)

    sql += " ORDER BY txn_date DESC, created_at DESC"

    return execute_query(sql, "inventory_transactions", params=tuple(params) if params else None)


