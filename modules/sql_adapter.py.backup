# LEGACY COMPAT: read_solution_batch
# ==========================================================

def read_solution_batch(product_id: int = None) -> pd.DataFrame:
    """
    Solution/accessory stock from batches table.
    All three price tiers returned:
      mrp           = retail counter price
      selling_price = W/S trade price
      purchase_rate = cost / inward price
    """
    sql = """
        SELECT
            id AS batch_id,
            id AS id,
            batch_no,
            product_id,
            mfg_date,
            exp_date,
            COALESCE(mrp, selling_price, cost_price, 0)           AS mrp,
            COALESCE(selling_price, mrp, cost_price, 0)           AS selling_price,
            COALESCE(cost_price, 0)                               AS purchase_rate,
            COALESCE(qty_available, 0)                            AS qty_available,
            COALESCE(qty_available, 0)                            AS quantity,
            COALESCE(is_active, true) AS is_active
        FROM batches
        WHERE COALESCE(is_active, true) = true
    """

    params = []

    if product_id:
        sql += " AND product_id = %s"
        params.append(product_id)

    return execute_query(
        sql,
        "batches",
        params=tuple(params) if params else None
    )
